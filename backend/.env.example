# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=nasdashboard
DB_PASSWORD=your_secure_password_here
DB_NAME=nasdashboard
DB_SSLMODE=disable

# JWT 配置
JWT_SECRET=your_jwt_secret_key_change_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_in_production
JWT_ACCESS_TOKEN_EXPIRY_HOURS=24
JWT_REFRESH_TOKEN_EXPIRY_DAYS=30

# 服务器配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8888
GIN_MODE=release

# 备份配置
BACKUP_AUTO_ENABLED=true
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *" # 每天凌晨2点

# 插件配置
PLUGIN_DIR=/opt/nas-dashboard/plugins
PLUGIN_AUTO_START=true

# 日志配置
LOG_LEVEL=info
LOG_FILE=/var/log/nas-dashboard/app.log

# 系统配置
SYSTEM_NAME=NAS Dashboard
SYSTEM_TIMEZONE=Asia/Shanghai
SYSTEM_LANGUAGE=en

# 安全配置
SECURITY_SESSION_TIMEOUT=86400
SECURITY_MAX_LOGIN_ATTEMPTS=5
SECURITY_PASSWORD_MIN_LENGTH=8

# WebSocket 配置
WS_HEARTBEAT_INTERVAL=30
WS_MESSAGE_BUFFER_SIZE=256

# 文件管理配置
FILE_MAX_UPLOAD_SIZE=104857600 # 100MB
FILE_ALLOWED_EXTENSIONS=.txt,.doc,.docx,.pdf,.jpg,.jpeg,.png,.gif,.mp4,.zip
FILE_QUOTA_ENABLED=false
FILE_DEFAULT_QUOTA=10737418240 # 10GB