				network.GET("/interfaces/ethernet", api.GetEthernetInterfaces)
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
				network.GET("/interfaces/wifi", api.GetWiFiInterfaces)
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
						// 接口配置管理（参数化路由）
