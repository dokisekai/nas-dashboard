piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
		{
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
			power.GET("/current", api.GetPowerCurrent)
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
			power.GET("/history", api.GetPowerHistory)
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
