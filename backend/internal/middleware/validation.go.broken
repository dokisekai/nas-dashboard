func SanitizeInput(c *gin.Context) {
	// 对于POST/PUT请求，检查潜在的恶意输入
	if c.Request.Method == "POST" || c.Request.Method == "PUT" {
		// 这里可以添加输入清理逻辑
		// 例如: 移除HTML标签、转义特殊字符等
	}
