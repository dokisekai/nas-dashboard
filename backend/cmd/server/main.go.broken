piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
		}
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)

piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
			// 网络管理路由
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
			network := apiGroup.Group("/network")
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
			network.Use(middleware.Auth())
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
			{
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
				// 网络接口管理
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
