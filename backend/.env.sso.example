# SSO服务器配置示例
# 复制此文件为 .env.sso 并根据实际情况修改

# ============================================
# SSO服务器基本配置
# ============================================
SSO_ISSUER_URL=http://localhost:8888
SSO_CLIENT_ID=nas-dashboard
SSO_SECRET=your-super-secret-jwt-key-change-this-in-production
SSO_REDIRECT_URI=http://localhost:5177/sso/callback
SSO_AUTO_CREATE_USER=true

# ============================================
# Google OAuth配置
# ============================================
# 获取步骤: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8888/sso/callback

# ============================================
# GitHub OAuth配置
# ============================================
# 获取步骤: https://github.com/settings/developers
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:8888/sso/callback

# ============================================
# Microsoft Azure AD OAuth配置
# ============================================
# 获取步骤: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps/ApplicationsListBlade
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://localhost:8888/sso/callback
MICROSOFT_TENANT=common  # common, organizations, consumers, 或具体的租户ID

# ============================================
# LDAP/AD配置
# ============================================
LDAP_SERVER=ldap.example.com
LDAP_PORT=389
LDAP_BASE_DN=dc=example,dc=com
LDAP_BIND_DN=cn=admin,dc=example,dc=com
LDAP_BIND_PASSWORD=your-ldap-bind-password
LDAP_USER_FILTER=(uid=%s)

# ============================================
# Immich应用配置
# ============================================
IMMICH_SERVER_URL=http://localhost:2283
IMMICH_API_KEY=your-immich-api-key

# ============================================
# OAuth客户端配置
# ============================================
# 这些客户端可以向SSO服务器请求授权
# 格式: CLIENT_ID=CLIENT_SECRET:REDIRECT_URI

# 示例客户端配置
# test-client:test-secret:http://localhost:3000/callback
# frontend-app:frontend-secret:http://localhost:8080/auth/callback