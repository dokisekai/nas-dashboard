piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
			storage.POST("/disks/:device/benchmark", api.RunDiskBenchmark)
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)

piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
			// RAID管理
piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
			storage.GET("/raid", api.GetRAIDArrays)
