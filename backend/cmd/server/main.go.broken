piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)

piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)

piGroup.GET("/immich/auth-login", middleware.Auth(), api.ImmichAuthLogin)
